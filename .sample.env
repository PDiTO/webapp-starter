# Local development:
# Do not create this by hand unless you know what you are doing.
# `pnpm convex:dev --configure existing` writes these to `.env.local`:
# CONVEX_DEPLOYMENT=
# NEXT_PUBLIC_CONVEX_URL=
# NEXT_PUBLIC_CONVEX_SITE_URL=
#
# Production frontend:
# Set this in your hosting platform:
# NEXT_PUBLIC_CONVEX_URL=
